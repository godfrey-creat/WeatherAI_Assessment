# Copy this file to .env and fill in your values
# Get your WeatherAI API key from: https://weather-ai.co/dashboard → API Keys

SECRET_KEY=django-insecure-change-this-to-a-random-string-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# WeatherAI API key (prefixed with wai_)
WEATHERAI_API_KEY=wai_your_api_key_here
